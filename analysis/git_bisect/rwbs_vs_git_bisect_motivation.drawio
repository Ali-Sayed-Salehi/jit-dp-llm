        <mxCell id="43" value="&lt;b&gt;RWBS&lt;/b&gt; (Risk-Weighted Bisection, sum mass)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="465" width="560" height="24" as="geometry" />
