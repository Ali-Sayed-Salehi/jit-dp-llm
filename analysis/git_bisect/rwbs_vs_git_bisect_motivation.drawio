        <mxCell id="92" value="C9&lt;br&gt;0.02" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f5f5f5;strokeColor=#1f4e79;strokeWidth=3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="436" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="93" value="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="399" y="928" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="94" value="2" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="223" y="928" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="95" value="Ranking is by per-commit risk, not by interval balance." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="34" y="1010" width="430" height="18" as="geometry" />
        </mxCell>

        <mxCell id="96" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fafafa;strokeColor=#d9d9d9;" vertex="1" parent="1">
          <mxGeometry x="540" y="795" width="500" height="240" as="geometry" />
        </mxCell>
        <mxCell id="97" value="&lt;b&gt;Step 2&lt;/b&gt;&lt;br&gt;TKRB tries the top-ranked candidate first: C8.&lt;br&gt;Its rule is to test the predecessor and the candidate, so it tests C7 -&gt; PASS and then C8 -&gt; FAIL. That is enough to identify the culprit immediately." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#d9d9d9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="554" y="809" width="472" height="104" as="geometry" />
        </mxCell>
        <mxCell id="98" value="C0&lt;br&gt;good" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="99" value="C1&lt;br&gt;0.02" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f5f5f5;strokeColor=#b3b3b3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="604" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="100" value="C2&lt;br&gt;0.10" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="648" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="101" value="C3&lt;br&gt;0.02" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f5f5f5;strokeColor=#b3b3b3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="692" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="102" value="C4&lt;br&gt;0.25" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="736" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="103" value="C5&lt;br&gt;0.02" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f5f5f5;strokeColor=#b3b3b3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="780" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="104" value="C6&lt;br&gt;0.15" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="824" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="105" value="C7&lt;br&gt;0.02" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f5f5f5;strokeColor=#82b366;strokeWidth=3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="868" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="106" value="C8&lt;br&gt;0.95" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="912" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="107" value="C9&lt;br&gt;0.02" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f5f5f5;strokeColor=#1f4e79;strokeWidth=3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="956" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="108" value="1P" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="875" y="928" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="109" value="2F" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="919" y="928" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="110" value="B" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#dae8fc;strokeColor=#1f4e79;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="963" y="928" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="111" value="The top-ranked candidate succeeds immediately, so TKRB never needs its fallback bisect phase." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="610" y="1010" width="320" height="18" as="geometry" />
        </mxCell>

        <mxCell id="112" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fafafa;strokeColor=#d9d9d9;" vertex="1" parent="1">
          <mxGeometry x="1060" y="795" width="500" height="240" as="geometry" />
        </mxCell>
        <mxCell id="113" value="&lt;b&gt;Step 3&lt;/b&gt;&lt;br&gt;TKRB isolates the culprit in its risk-first phase using the pair C7(P), C8(F).&lt;br&gt;The second-ranked candidate C4 is never used.&lt;br&gt;&lt;b&gt;Total = 2 tests&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#d9d9d9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1074" y="809" width="472" height="92" as="geometry" />
        </mxCell>
        <mxCell id="114" value="C7&lt;br&gt;good" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1220" y="960" width="90" height="46" as="geometry" />
        </mxCell>
        <mxCell id="115" value="C8&lt;br&gt;0.95" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="960" width="90" height="46" as="geometry" />
        </mxCell>
        <mxCell id="116" value="P" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1252" y="928" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="117" value="F" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1352" y="928" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="118" value="TKRB wins for a different reason than RWBS: it checks the highest-risk point directly." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1010" width="360" height="18" as="geometry" />
        </mxCell>

        <mxCell id="119" value="&lt;b&gt;Why this version is clearer&lt;/b&gt;&lt;br&gt;The diagram now shows a full 10-commit local history C0..C9, with C0 drawn explicitly as the known-good boundary. The elevated-risk commits are scattered across C2, C4, C6, and C8 rather than forming a single tight block. Even in that noisier pattern, standard midpoint git bisect still burns three passing probes, while RWBS and TKRB both reach the culprit in two tests by using the risk signal differently." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f5f5f5;strokeColor=#d9d9d9;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="20" y="1060" width="1540" height="78" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
