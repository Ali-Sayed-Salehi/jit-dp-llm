        <mxCell id="88" value="C5&lt;br&gt;0.02" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f5f5f5;strokeColor=#b3b3b3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="260" y="960" width="40" height="46" as="geometry" />
        </mxCell>
        <mxCell id="89" value="C6&lt;br&gt;0.15" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
