        <mxCell id="73" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fafafa;strokeColor=#d9d9d9;" vertex="1" parent="1">
          <mxGeometry x="1060" y="495" width="500" height="240" as="geometry" />
        </mxCell>
        <mxCell id="74" value="&lt;b&gt;Step 3&lt;/b&gt;&lt;br&gt;RWBS now has C7(P) and C8(F), so the culprit is isolated immediately.&lt;br&gt;&lt;b&gt;Total = 2 tests&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#d9d9d9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1074" y="509" width="472" height="78" as="geometry" />
        </mxCell>
        <mxCell id="75" value="C7&lt;br&gt;good" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1220" y="660" width="90" height="46" as="geometry" />
        </mxCell>
        <mxCell id="76" value="C8&lt;br&gt;0.95" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="660" width="90" height="46" as="geometry" />
        </mxCell>
        <mxCell id="77" value="P" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1252" y="628" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="78" value="F" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1352" y="628" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="79" value="RWBS wins here by using the cumulative risk mass, not by lucking into a midpoint." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1130" y="710" width="340" height="18" as="geometry" />
        </mxCell>

        <mxCell id="80" value="&lt;b&gt;TKRB&lt;/b&gt; (Top-K risk-first bisection, k = 2)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="765" width="560" height="24" as="geometry" />
        </mxCell>
        <mxCell id="81" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fafafa;strokeColor=#d9d9d9;" vertex="1" parent="1">
          <mxGeometry x="20" y="795" width="500" height="240" as="geometry" />
        </mxCell>
        <mxCell id="82" value="&lt;b&gt;Step 1&lt;/b&gt;&lt;br&gt;TKRB ranks commits by individual risk instead of balancing intervals.&lt;br&gt;The top-2 candidates in (C0,C9] are C8 (0.95) and C4 (0.25), marked with rank badges 1 and 2." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#d9d9d9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="34" y="809" width="472" height="94" as="geometry" />
        </mxCell>
        <mxCell id="83" value="C0&lt;br&gt;good" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="960" width="40" height="46" as="geometry" />
