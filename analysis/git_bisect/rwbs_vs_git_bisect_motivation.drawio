        <mxCell id="65" value="C4&lt;br&gt;0.25" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="752" y="660" width="44" height="46" as="geometry" />
