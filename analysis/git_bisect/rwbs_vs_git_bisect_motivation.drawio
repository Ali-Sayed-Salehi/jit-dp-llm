        <mxCell id="71" value="B" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#dae8fc;strokeColor=#1f4e79;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="953" y="628" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="72" value="The weighted split still points at C8, but C8 is no longer a legal interior test, so RWBS backs off to C7." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="554" y="710" width="450" height="18" as="geometry" />
