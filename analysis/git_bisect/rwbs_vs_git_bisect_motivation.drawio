        <mxCell id="64" value="C3&lt;br&gt;0.02" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#f5f5f5;strokeColor=#b3b3b3;align=center;verticalAlign=middle;fontFamily=Courier New;fontSize=8;" vertex="1" parent="1">
