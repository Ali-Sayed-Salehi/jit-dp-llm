        </mxCell>
        <mxCell id="45" value="&lt;b&gt;Step 1&lt;/b&gt;&lt;br&gt;RWBS balances summed risk mass instead of commit count.&lt;br&gt;Across (C0,C9], total risk = 1.55 and half = 0.775. Prefix through C7 = 0.58, while prefix through C8 = 1.53, so RWBS jumps to C8 -&gt; FAIL." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#d9d9d9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=12;" vertex="1" parent="1">
