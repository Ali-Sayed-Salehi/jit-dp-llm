        </mxCell>
        <mxCell id="5" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;S = current bad boundary&lt;br&gt;P = tested commit passed&lt;br&gt;F = tested commit failed&lt;br&gt;T = trigger commit (RATLB)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;fontSize=12;" vertex="1" parent="1">
